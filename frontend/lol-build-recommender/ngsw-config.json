{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/og-image.png",
          "/site.webmanifest",
          "/**/*.woff2"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-data",
      "urls": ["/api/data/champions", "/api/data/version", "/api/data/items"],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "1h",
        "strategy": "freshness",
        "timeout": "5s"
      }
    },
    {
      "name": "ddragon",
      "urls": ["https://ddragon.leagueoflegends.com/**"],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "7d",
        "strategy": "performance"
      }
    }
  ]
}
