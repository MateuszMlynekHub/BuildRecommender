<?xml version="1.0" encoding="UTF-8"?>
<!--
  DraftSense sitemap. Listed routes are the static, crawlable entry points —
  the /game path is dynamic (requires a summoner lookup) so it's excluded from
  indexing; there's no meaningful content for Google to cache for that URL.

  xhtml:link hreflang lets Google associate the Polish-primary site with an
  English alternate. Both point at the same URL because the UI is bilingual
  and language falls out of browser prefs, not URL structure.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <url>
    <loc>https://draftsense.net/</loc>
    <xhtml:link rel="alternate" hreflang="pl" href="https://draftsense.net/"/>
    <xhtml:link rel="alternate" hreflang="en" href="https://draftsense.net/"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="https://draftsense.net/"/>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
</urlset>
