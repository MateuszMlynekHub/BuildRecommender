# -----------------------------------------------------------------------------
# Production environment variables for DraftSense
# -----------------------------------------------------------------------------
# Copy this file to `.env` on the VPS and fill in the real values:
#     cp .env.example .env
#     chmod 600 .env          # only the deploy user should read the secrets
#     nano .env
#
# After editing, (re)start the stack:
#     docker compose up -d --build
#
# NEVER commit the populated .env — .gitignore excludes it, but double-check
# with `git status` before any git add -A.
# -----------------------------------------------------------------------------

# --- Riot API ----------------------------------------------------------------
# Production API key from https://developer.riotgames.com/app-type
# Dev keys (RGAPI-...) expire every 24 hours — use a registered Personal or
# Production key for real deployments. If this is empty, the backend refuses
# to start in Production mode (see Program.cs validation).
RIOT_API_KEY=RGAPI-replace-me

# --- Public hostname ---------------------------------------------------------
# The domain served by Caddy. Must have an A (and/or AAAA) DNS record pointing
# at the VPS public IP BEFORE first start, otherwise Let's Encrypt's HTTP-01
# challenge fails and the stack can't issue a certificate.
#
# Example values: draftsense.net, staging.draftsense.net, mojapp.pl
PUBLIC_DOMAIN=draftsense.net

# --- ACME email --------------------------------------------------------------
# Let's Encrypt contact address for cert expiry notifications. Use a real inbox
# that the operator actually reads — Let's Encrypt emails you 20 days before
# any cert expires if auto-renewal hasn't succeeded yet.
ACME_EMAIL=admin@draftsense.net
