{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LoLBuildRecommender.Infrastructure.BuildStats": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "RiotApi": {
    "ApiKey": ""
  },
  "BuildStats": {
    "DatabasePath": "data/build-stats.db",
    "Region": "euw1",
    "IncludeChallenger": true,
    "IncludeGrandmaster": true,
    "IncludeMaster": true,
    "MaxPlayers": 600,
    "MatchesPerPlayer": 100,
    "MaxTotalMatches": 0,
    "RequestDelayMs": 1400,
    "CrawlIntervalMinutes": 60,
    "StartupDelaySeconds": 30,
    "BackfillDays": 7,
    "BackfillSinceDate": "2026-01-08"
  }
}
